{
    "name": "cakephp/app",
    "description": "CakePHP skeleton app",
    "homepage": "https://cakephp.org",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.0",
        "cakedc/users": "^11.1",
        "cakephp/cakephp": "^4.4",
        "cakephp/localized": "^4.1",
        "cakephp/migrations": "^3.2",
        "cakephp/plugin-installer": "^1.3",
        "crabstudio/recaptcha": "^3.0",
        "firebase/php-jwt": "^6.8",
        "friendsofcake/bootstrap-ui": "^4.0.0",
        "friendsofcake/cakephp-csvview": "^4.1",
        "friendsofcake/search": "^6.2",
        "geocoder-php/geoip2-provider": "^4.3",
        "geocoder-php/google-maps-provider": "^4.7",
        "guzzlehttp/guzzle": "^7.4",
        "mailchimp/marketing": "^3.0",
        "middlewares/trailing-slash": "^2.0",
        "mobiledetect/mobiledetectlib": "^2.8",
        "php-http/cakephp-adapter": "^0.3.2",
        "php-http/message": "^1.13",
        "riesenia/cakephp-duplicatable": "^4.0"
    },
    "require-dev": {
        "cakedc/cakephp-phpstan": "^2.0",
        "cakephp/bake": "^2.6",
        "cakephp/cakephp-codesniffer": "^4.5",
        "cakephp/debug_kit": "^4.5",
        "cakephp/repl": "^0.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^0.7.2",
        "dereuromark/cakephp-ide-helper": "^1.17",
        "josegonzalez/dotenv": "^3.2",
        "lordsimal/cakephp-psalm": "@dev",
        "phpstan/extension-installer": "^1.1",
        "phpstan/phpstan": "^1.4",
        "phpunit/phpunit": "~8.5.0 || ^9.3",
        "vimeo/psalm": "^4.22"
    },
    "suggest": {
        "markstory/asset_compress": "An asset compression plugin which provides file concatenation and a flexible filter system for preprocessing and minification.",
        "dereuromark/cakephp-ide-helper": "After baking your code, this keeps your annotations in sync with the code evolving from there on for maximum IDE and PHPStan/Psalm compatibility.",
        "phpstan/phpstan": "PHPStan focuses on finding errors in your code without actually running it. It catches whole classes of bugs even before you write tests for the code."
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "Sitemap\\": "plugins/Sitemap/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Test\\": "tests/",
            "Cake\\Test\\": "vendor/cakephp/cakephp/tests/",
            "Sitemap\\Sitemap\\": "plugins/Sitemap/tests/"
        }
    },
    "scripts": {
        "post-install-cmd": "App\\Console\\Installer::postInstall",
        "post-create-project-cmd": "App\\Console\\Installer::postInstall",
        "check": [
            "@test",
            "@cs-check"
        ],
        "cs-check": "phpcs --colors -p  src/ tests/",
        "cs-fix": "phpcbf --colors -p src/ tests/",
        "psalm": "psalm --show-info=false src/",
        "psalm-rebuild-baseline": "psalm --show-info=false  --set-baseline=psalm-baseline.xml  src/",
        "stan": "phpstan analyse",
        "stan-rebuild-baseline": "phpstan analyse --level 7 --configuration phpstan.neon src/ --generate-baseline",
        "test": "phpunit --colors=always",
        "test-working": "XDEBUG_MODE=coverage vendor/bin/phpunit --coverage-html webroot/coverage --testdox --testsuite working"
    },
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "cakephp/plugin-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        }
    }
}
